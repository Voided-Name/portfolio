---
import Layout from "../layouts/Layout.astro";
import { Image } from "astro:assets";
import profileImage from "../assets/images/profile.png";
---

<Layout>
  <div
    class="min-h-[calc(101vh-70px)] ring-1 ring-green-400/40 main-content bg-slate-950 overflow-hidden flex justify-center items-center"
  >
    <div class="p-4 w-full flex-col justify-center">
      <Image
        src={profileImage}
        alt="Profile Picture"
        class="w-64 object-contain rounded-full mx-auto border border-green-400"
      />
      <h1 class="text-green-400 text-5xl text-center spotlight-text">
        Nash Andre Berber
      </h1>
      <h1 class="text-green-400 text-center spotlight-text">
        Back-End Developer
      </h1>
      <p class="text-green-400 spotlight-text text-center">
        Born in 2004 in Cabanatuan, Philippines.
      </p>
      <p class="text-center text-green-400 spotlight-text">
        Lorem ipsum dolor sit amet, consectetur adipiscing elit. Proin vel leo
        et felis iaculis congue et vel sapien. Pellentesque varius, sapien a
        vulputate tincidunt, eros quam convallis turpis, vel commodo ipsum nibh
        sit amet ante. Nam bibendum lectus risus, non convallis sem convallis
        at. Suspendisse mauris odio, maximus ut dapibus id, rhoncus id eros.
        Fusce quis ipsum lorem. Duis vulputate facilisis vulputate. Maecenas nec
        turpis urna. Aliquam semper laoreet pharetra.
      </p>
    </div>
  </div>
</Layout>

<style>
  .main-content {
    background-image:
      radial-gradient(
        circle at var(--clientX, 50%) var(--clientY, 50%),
        oklch(12.9% 0.042 264.695) 5em,
        transparent 10em
      ),
      radial-gradient(oklch(44.8% 0.119 151.328) 1px, transparent 0);
    background-size:
      auto,
      40px 40px;
    background-position:
      0 0,
      calc(-19px + var(--clientX, 0px) * 0.05)
        calc(-19px + var(--clientY, 0px) * 0.05);
  }
</style>
<script>
  document.body.addEventListener("mousemove", (e) => {
    document.body.style.setProperty("--clientX", e.clientX + "px");
    document.body.style.setProperty("--clientY", e.clientY + "px");
  });

  document.body.addEventListener("mousemove", (e) => {
    document.body.style.setProperty("--clientX", e.clientX + "px");
    document.body.style.setProperty("--clientY", e.clientY + "px");

    document.querySelectorAll(".spotlight-word").forEach((word) => {
      const rect = word.getBoundingClientRect();
      const cx = rect.left + rect.width / 2;
      const cy = rect.top + rect.height / 2;
      const dist = Math.hypot(e.clientX - cx, e.clientY - cy);

      // Brightness falls off with distance; tweak 150 to control radius
      const brightness = Math.max(0, 1 - dist / 600);
      const opacity = 0.7 + brightness * 0.7; // min 30%, max 100%
      (word as HTMLElement).style.opacity = String(opacity);
    });
  });

  document.querySelectorAll(".spotlight-text").forEach((el) => {
    el.innerHTML = el.innerText
      .split(" ")
      .map(
        (w) =>
          `<span class="spotlight-word" style="opacity:0.3;transition:opacity 0.1s">${w}</span>`,
      )
      .join(" ");
  });
</script>
